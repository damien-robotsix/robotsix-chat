# deploy/.env.example
#
# Copy to deploy/.env and fill in the values before starting the stack:
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up -d
#
# Prerequisites (not parameterised as env vars — the compose file expects these):
#   1. Claude credentials:  the host path ~/.claude is mounted read-only into
#      the container.  Ensure it exists and contains valid Claude subscription
#      credentials (e.g. ~/.claude/credentials.json).
#   2. Config file:  copy deploy/config.example.yaml to config/chat.local.yaml
#      and fill in real values (secret slots, tune defaults).  The container
#      reads this file via the CHAT_CONFIG_PATH env var (infrastructure wiring).
#      config/chat.local.yaml is git-ignored so credentials never land in the
#      repo.

# GHCR image tag to deploy.
# Typical values: "main" (continuous deploy), "v1.2.3" (semver release), or a
# full commit SHA for pinning.
IMAGE_TAG=main

# Host loopback port the chat server will be exposed on.
CHAT_PORT=8088

# Agent instruction (system prompt). Overrides agent.instruction from YAML config.
# AGENT_INSTRUCTION=You are a helpful assistant.

# CORRELATION_ID_HEADER=X-Request-ID
