# Version control
.git/
.github/
.gitignore

# Python caches and bytecode
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# Build artifacts
dist/
build/
*.egg-info/

# Local config / secrets (never enter the image)
.env
.env.*

# Tooling / dev cruft
.pre-commit-config.yaml
.robotsix-mill/

# Docs and tests (not needed at runtime)
docs/
tests/
mkdocs.yml

# Container files
Dockerfile
.dockerignore
