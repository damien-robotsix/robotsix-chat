{
  "config": {
    "MD013": false,   // line-length — mdformat wraps, .editorconfig sets 100
    "MD033": false,   // inline HTML — mkdocs-material needs it
    "MD041": false,   // first-line heading — mkdocs pages start with frontmatter
    "MD045": true,    // alt-text on images (accessibility)
    "MD059": true     // descriptive link text
  }
}
