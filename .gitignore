# Byte-compiled / optimized files
__pycache__/
*.pyc

# Virtual environments
.venv/

# Environment secrets
.env

# Real local configuration (may contain credentials: API keys, passwords)
config/chat.local.yaml
config/*.local.yaml
!config/*.local.example.yaml

# Build artifacts
dist/
build/
*.egg-info/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
# coverage data
.coverage
.coverage.*

# mkdocs build output
site/

# Persistent deploy-time agent data (bind-mounted into the container)
deploy/data/

# Secret material (API keys etc.) — never commit
*.secrets
cogney-key.secrets
