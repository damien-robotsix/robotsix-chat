# Benchmark history (pytest-benchmark --benchmark-autosave)
.benchmarks/

# Byte-compiled / optimized files
__pycache__/
*.pyc

# Virtual environments
.venv/

# Environment secrets
.env

# Real local configuration (may contain credentials: API keys, passwords).
# The committed config/config.json is the defaults template (config standard);
# point ROBOTSIX_CONFIG_FILE at this gitignored file for local runs with
# real credentials.
config/config.local.json
# Pre-standard local config files (YAML era) — never commit
config/chat.local.yaml

# Build artifacts
dist/
build/
*.egg-info/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
# coverage data
.coverage
.coverage.*

# mkdocs build output
site/

# Persistent deploy-time agent data (bind-mounted into the container)
deploy/data/
# Local runtime agent data (never committed — runtime state, not source)
.data/

# Secret material (API keys etc.) — never commit
*.secrets
cogney-key.secrets

# Runtime artifacts — persistent data written during test runs / local dev

# MagicMock paths: when MagicMock objects are passed to Path(), they resolve
# to real filesystem paths like MagicMock/mock.xxx.yyy/... and _save_sessions()
# writes actual files there.  These are test artifacts, never source.
MagicMock/

# Vendored deps installed into the tree during sandboxed builds/tests
# (e.g. pip/uv install --target local-deps). Generated, never committed —
# without this they flood the implement diff and trip scope-triage.
local-deps/
.local_pkgs/
.deps/
.pip-packages/
.local-packages/

# Pip/uv-generated entry-point wrappers accidentally swept into the source tree
src/bin/

# vendored sandbox deps (build artifact)
.deps/
.pip-packages/
.local-packages/
# Catch dotted/new variants of the uv-install vendored dirs (recurring flood)
.local-deps/
*-deps/
*-packages/

# Pre-commit tool binaries accidentally committed during local testing
actionlint
shellcheck

# Core dumps — binary artifacts, can contain sensitive memory
core
