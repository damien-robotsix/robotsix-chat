# Environment overrides for robotsix-chat (copy to .env; optional).
# The primary config is YAML (config/chat.local.yaml) — these env vars override
# it field-by-field. See README "Configuration".

# LLM selection (robotsix-llmio): capability level 1 (cheapest) .. 4 (frontier).
# Levels 3-4 = claude-sdk (keyless; 3 = opus, 4 = fable-5). Levels 1-2 = openrouter-deepseek (need a key).
LLMIO_MODEL_LEVEL=3
# LLMIO_API_KEY=sk-or-...        # required for levels 1-2 (OpenRouter)

# Agent instruction (system prompt). Overrides agent.instruction from YAML config.
# AGENT_INSTRUCTION=You are a helpful assistant.

# Server.
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
LOG_LEVEL=INFO
# CORS_ALLOW_ORIGINS=
# CORRELATION_ID_HEADER=X-Request-ID
# IDLE_TIMEOUT_MINUTES=30     # 0 disables; UI auto-restarts conversation after N idle minutes

# Long-term memory (cognee) — disabled by default; needs `uv sync --extra memory`.
# When enabled, MEMORY_LLM_API_KEY (OpenRouter) and MEMORY_EMBEDDING_ENDPOINT
# (remote OpenAI-compatible embedding server, e.g. self-hosted Ollama) are required.
# MEMORY_ENABLED=true
# MEMORY_LLM_API_KEY=sk-or-...
# MEMORY_EMBEDDING_ENDPOINT=http://host:11434/v1
# MEMORY_DATA_DIR=.data/cognee
# MEMORY_LLM_MODEL=openrouter/deepseek/deepseek-v4-flash
# MEMORY_EMBEDDING_MODEL=bge-m3
# MEMORY_EMBEDDING_DIMENSIONS=1024
# MEMORY_RECALL_SEARCH_TYPE=GRAPH_COMPLETION

# robotsix-mill integration over the agent-comm broker — disabled by default;
# needs `uv sync --extra broker`. When enabled, MILL_BROKER_TOKEN (this agent's
# bearer token, registered on the broker) is required.
# MILL_ENABLED=true
# MILL_BROKER_TOKEN=...
# MILL_BROKER_HOST=ai-broker.robotsix.net
# MILL_BROKER_PORT=443
# MILL_BOARD_MANAGER_ID=board-manager-robotsix-mill
# MILL_REPO_ID=              # empty → board manager picks the target repo

# robotsix-calendar-agent integration over the agent-comm broker — disabled by
# default; needs `uv sync --extra broker`. When enabled, CALENDAR_BROKER_TOKEN
# (this agent's bearer token, registered on the broker) is required.
# CALENDAR_ENABLED=true
# CALENDAR_BROKER_TOKEN=...
# CALENDAR_BROKER_HOST=ai-broker.robotsix.net
# CALENDAR_CALENDAR_AGENT_ID=robotsix-calendar

# Direct HTTP access to the auto-mail board server — disabled by default.
# When enabled, the chat agent gains discrete tools (get board, check status,
# move / delete / archive emails, run triage) that call the auto-mail board
# HTTP API directly.  Default api_base_url targets the local server at :8077.
# MAIL_ENABLED=true
# MAIL_API_BASE_URL=http://127.0.0.1:8077
# MAIL_API_TOKEN=...

# Direct board HTTP read access — lets the assistant list/read tickets from the
# same HTTP endpoint the browser UI uses (read parity with the user). Disabled
# by default; independent of mill.enabled (works over HTTP even when the broker
# is offline). Default api_base_url targets the mill's local API at :8077.
# BOARD_READER_ENABLED=true
# BOARD_READER_API_BASE_URL=http://127.0.0.1:8077
# BOARD_READER_API_TOKEN=     # empty = no auth header; set for bearer auth

# Direct-repository-capability — lets the agent push branches and open PRs
# against repos in the robotsix-mill GitHub App installation scope,
# authenticating as the app (JWT → short-lived installation token).
# Guardrails: only for BLOCKED tickets; dynamic repo scope from installation;
# no auto-merge; no merge capability. Disabled by default.
# DIRECT_REPO_ENABLED=true
# DIRECT_REPO_GITHUB_APP_ID=
# DIRECT_REPO_GITHUB_APP_PRIVATE_KEY=
# DIRECT_REPO_GITHUB_APP_INSTALLATION_ID=
# DIRECT_REPO_GITHUB_API_BASE_URL=https://api.github.com
# DIRECT_REPO_BOARD_API_BASE_URL=http://127.0.0.1:8077
# DIRECT_REPO_BOARD_API_TOKEN=
# DIRECT_REPO_TIMEOUT=30.0

# Writable knowledge base — local JSON, always-on (default: true). The agent uses
# five tools (add/append/update/list/read_knowledge_note) to persist operational
# notes and lessons across sessions. Disable with KNOWLEDGE_ENABLED=false.
# KNOWLEDGE_ENABLED=true
# KNOWLEDGE_PATH=.data/knowledge.json
